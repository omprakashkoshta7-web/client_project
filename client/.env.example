# SpeedCopy Client Environment Configuration
# Copy this file to .env and update the values

# Primary API Configuration
VITE_API_BASE_URL=https://product-202671058278.asia-south1.run.app
VITE_ENVIRONMENT=production

# Service URLs - Google Cloud Run Deployment
VITE_GATEWAY_URL=https://gateway-202671058278.asia-south1.run.app
VITE_AUTH_URL=https://auth-202671058278.asia-south1.run.app
VITE_PRODUCT_URL=https://product-202671058278.asia-south1.run.app
VITE_ADMIN_URL=https://admin-202671058278.asia-south1.run.app
VITE_FINANCE_URL=https://finance-202671058278.asia-south1.run.app
VITE_DESIGN_URL=https://design-202671058278.asia-south1.run.app
VITE_NOTIFICATION_URL=https://notification-202671058278.asia-south1.run.app

# API Configuration
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_CACHING=true
VITE_ENABLE_FALLBACK=true

# Debug Settings
VITE_DEBUG_API=true
VITE_LOG_LEVEL=info

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here

# Payment Configuration
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# App Configuration
VITE_APP_NAME=SpeedCopy
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Fast and reliable printing, gifting, and shopping platform